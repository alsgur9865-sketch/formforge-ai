# =====================================================
# FormForge AI — 환경 변수 템플릿
# 사용법: 이 파일을 .env로 복사 후 실제 값 채우기
#   cp .env.example .env
# =====================================================

# ---- Google Cloud ----
GOOGLE_CLOUD_PROJECT=formforge-prod
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ---- 모델 호출 모드 (Vertex AI 권장) ----
# True: service-account.json + Vertex AI 경유 (GCP 크레딧 사용, gemini-2.5-pro 호출 가능)
# False(또는 미설정): GEMINI_API_KEY(AI Studio) 사용. 단 2.5-pro 는 무료 tier 없음.
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_LOCATION=us-central1   # ADK 는 이 변수를 봄

# AI Studio fallback (Vertex 모드에서는 무시됨)
GEMINI_API_KEY=                    # https://aistudio.google.com/apikey

# ---- Vertex AI (Vector Search 등) ----
VERTEX_AI_LOCATION=us-central1
VECTOR_SEARCH_INDEX_ID=            # Day 10 (Task 10.x) 이후 채움
VECTOR_SEARCH_ENDPOINT_ID=         # Day 10 (Task 10.x) 이후 채움

# ---- Arize Phoenix Cloud ----
PHOENIX_API_KEY=                   # https://app.phoenix.arize.com → Settings → API Keys
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_PROJECT_NAME=formforge-prod

# ---- Firestore ----
FIRESTORE_DATABASE=(default)

# ---- App ----
APP_ENV=development                # development | production
MAX_DEBATE_ROUNDS=3
